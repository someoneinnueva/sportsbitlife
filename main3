      fill(theme.ACCENT, 22); noStroke(); rect(x + 14, y + 132, w - 28, 14, 7);
      fill(theme.ACCENT); textSize(8); textAlign(CENTER, CENTER);
      text(sc.rankLabel + " #" + p.career.worldRanking, x + w/2, y + 139);
    }

    y += 128;

