      line(x + 14, y + 2, x + w - 14, y + 2); noStroke();
      y += 10;

      // ── RELATIONSHIPS section ─────────────────────────
      if (y > PY + PH - 30) return;
      fill(theme.FAMILY); textSize(9); textAlign(LEFT, TOP);
      text("RELATIONSHIPS", x + 14, y); y += 14;

      if (p.family.spouse != null) {
