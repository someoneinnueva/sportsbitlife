      fill(theme.TEXT_DIM); textSize(8); textAlign(CENTER, TOP);
      String loc = p.nationality + (!p.hometown.isEmpty() ? "  ·  " + p.hometown : "");
      text(loc, x + LP_W/2, y + 118);
