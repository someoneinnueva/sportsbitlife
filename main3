    name         = n;
    type         = t;
    invested     = amt;
    currentValue = amt;
    switch (t) {
      case STOCKS:           weeklyReturnRate = 0.0020; volatility = 0.030; break;
      case CRYPTO:           weeklyReturnRate = 0.0040; volatility = 0.100; break;
