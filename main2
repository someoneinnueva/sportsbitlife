    statBarIcon("😊", "HAPPINESS", p.happiness, color(255, 210, 60), x + 14, y, w - 28); y += 34;
    statBarIcon("🧠", "SMARTS",    p.smarts,    theme.ACCENT2,       x + 14, y, w - 28); y += 34;
    statBarIcon("✨", "LOOKS",     p.looks,     theme.PURPLE,        x + 14, y, w - 28); y += 34;

