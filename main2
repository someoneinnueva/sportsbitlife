    drawLegacyStat("Total Titles", p.career.titlesWon + "",          x + 180, y + 20);
    drawLegacyStat("Best Ranking", "#" + p.career.worldRanking,      x + 340, y + 20);
    drawLegacyStat("Prize Money",  formatMoney(p.career.prizeMoney), x +  20, y + 80);
