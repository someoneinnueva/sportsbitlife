          fill(rc, 20); rect(x + 14, y, w - 28, 18, 4);
          fill(rc); textSize(8); textAlign(LEFT, CENTER);
          text(lbl + ": " + pr.name, x + 18, y + 9);
          textAlign(RIGHT, CENTER);
          text(pr.relationshipLabel(), x + w - 18, y + 9);
          y += 22;
