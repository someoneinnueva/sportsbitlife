    line(x + 14, y + 2, x + w - 14, y + 2); noStroke();
    y += 12;

    // ── PRO career stats ──────────────────────────────────
    if (phase == LifePhase.PRO) {
      fill(theme.TEXT_DIM); textSize(8); textAlign(LEFT, TOP);
      text("TITLES", x + 14, y); text("GS", x + 80, y); text("PRIZE", x + 116, y);
