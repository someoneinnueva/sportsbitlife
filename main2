        case 1: return buildFallback_SchoolProject();
        case 2: return buildFallback_NewFriend();
        case 3: return buildFallback_FamilyCall();
        case 4: return buildFallback_ChildhoodArgument();
        default: return buildFallback_FamilyHoliday();
